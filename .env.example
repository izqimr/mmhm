# ============================================================
# 环境变量配置模板
# ============================================================
# 
# 使用说明：
# 1. 根据运行环境复制此文件：
#    - 测试环境:    cp .env.example .env.test
#    - 预生产环境:  cp .env.example .env.pre
#    - 生产环境:    cp .env.example .env.prod
#    - 本地开发:    cp .env.example .env
#
# 2. 编辑相应的文件，填入实际凭证
#
# 3. 运行测试：
#    - 所有环境文件会自动加载到 git 历史中，但提交时被忽略
#    - 通过 ENVIRONMENT 环境变量切换: export ENVIRONMENT=pre
#
# ============================================================

# 环境标识
ENV=test

# 公共配置
HOST=https://test-digital.hnlshm.com
USERNAME=your_username
PASSWORD=your_password
APP_ID=store-selection-service
APP_SECRET=your_app_secret

# Franchise 数据库配置
FRANCHISE_DB_HOST=mysql.example.com
FRANCHISE_DB_USER=store_franchise_user
FRANCHISE_DB_PASSWORD=your_db_password
FRANCHISE_DB_PORT=3306
FRANCHISE_DATABASE=store_franchise

# Store 数据库配置
STORE_DB_HOST=mysql.example.com
STORE_DB_USER=store_core_user
STORE_DB_PASSWORD=your_db_password
STORE_DB_PORT=3306
STORE_DATABASE=store_core

# 日志配置
LOG_FILE_NAME=framework.log
LOG_LEVEL=INFO
